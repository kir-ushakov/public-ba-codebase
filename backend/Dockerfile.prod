FROM node:20

WORKDIR /usr/src/app

# Copy contracts package first
COPY contracts/ ../contracts/
WORKDIR /usr/src/contracts
RUN npm ci
RUN npm run build

# Build backend
WORKDIR /usr/src/app
COPY backend/package*.json ./
RUN npm ci --verbose

COPY backend/ .

RUN npx tsc

CMD ["node", "./dist/server.js"]
